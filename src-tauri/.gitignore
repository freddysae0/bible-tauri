/target/

# Tauri-generated mobile scaffolding — mostly regenerated by `tauri android init`.
# We keep a curated set of files under version control so push-notifications
# wiring (Firebase classpath, manifest entries, custom messaging service)
# survives. If you re-run `tauri android init`, re-apply the patches in
# docs/android-push-setup.md.
/gen/*
!/gen/android/
/gen/android/*
!/gen/android/build.gradle.kts
!/gen/android/settings.gradle
!/gen/android/app/
/gen/android/app/*
!/gen/android/app/build.gradle.kts
!/gen/android/app/src/
/gen/android/app/src/*
!/gen/android/app/src/main/
/gen/android/app/src/main/*
!/gen/android/app/src/main/AndroidManifest.xml
!/gen/android/app/src/main/java/
/gen/android/app/src/main/java/*
!/gen/android/app/src/main/java/study/
/gen/android/app/src/main/java/study/*
!/gen/android/app/src/main/java/study/tuliabible/
/gen/android/app/src/main/java/study/tuliabible/*
!/gen/android/app/src/main/java/study/tuliabible/PushMessagingService.kt

# Never commit Firebase service account / Google services JSON.
/gen/android/app/google-services.json
