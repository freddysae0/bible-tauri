{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tulia Bible",
  "version": "../package.json",
  "identifier": "study.tuliabible",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Tulia Bible",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "maximized": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/android/mipmap-mdpi/ic_launcher.png",
      "icons/android/mipmap-mdpi/ic_launcher_round.png",
      "icons/android/mipmap-hdpi/ic_launcher.png",
      "icons/android/mipmap-hdpi/ic_launcher_round.png",
      "icons/android/mipmap-xhdpi/ic_launcher.png",
      "icons/android/mipmap-xhdpi/ic_launcher_round.png",
      "icons/android/mipmap-xxhdpi/ic_launcher.png",
      "icons/android/mipmap-xxhdpi/ic_launcher_round.png",
      "icons/android/mipmap-xxxhdpi/ic_launcher.png",
      "icons/android/mipmap-xxxhdpi/ic_launcher_round.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI3NzJEQ0JCRkYzRUEyMjgKUldRb29qNy91OXh5SjMrRmtDaElxWE9zM3Nyc21ISlZBSVYycTBaazZ6M1EzekNidUZ5ZmphdWUK",
      "endpoints": [
        "https://github.com/freddysae0/bible-tauri/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "notification": {
      "all": true
    }
  }
}
