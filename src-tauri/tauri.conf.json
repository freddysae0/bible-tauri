{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tulia Study",
  "version": "../package.json",
  "identifier": "space.harbour.tulia-study",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Tulia Study",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "maximized": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE0QjU0NzhFREJFQjYxMzYKUldRMllldmJqa2UxcE1rVnBDVGp3ejZhR0tGSTM2SDdRYTZrdW9vSTE4U3lSU2JNRW8xb2l2MFYK",
      "endpoints": [
        "https://github.com/freddysae0/bible-tauri/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
